# Anthropic API key for Claude vision document extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection (use localhost for local dev, db service name in Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/freight_ap
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/freight_ap_test

# Redis connection (use localhost for local dev, redis service name in Docker)
REDIS_URL=redis://localhost:6379/0
# Redis Streams delivery policy
INVOICE_STREAM=freight-ap:invoice-jobs:v1
INVOICE_CONSUMER_GROUP=freight-ap:invoice-workers:v1
INVOICE_DEAD_LETTER_STREAM=freight-ap:invoice-jobs:dlq:v1
INVOICE_MAX_ATTEMPTS=3
INVOICE_VISIBILITY_TIMEOUT_MS=300000
INVOICE_READ_BLOCK_MS=5000
# Maximum documents processed concurrently by the invoice worker
MAX_BATCH_SIZE=10

# Missing required shipment-document SLA and scheduled scan cadence
MISSING_DOCUMENT_SLA_HOURS=72
MISSING_DOCUMENT_SCAN_INTERVAL_SECONDS=300

# Bounded health probes and background-task freshness
HEALTH_PROBE_TIMEOUT_SECONDS=1.0
GMAIL_POLL_INTERVAL_SECONDS=300
HEALTH_STALE_AFTER_MULTIPLIER=2.5

# Gmail OAuth files (download credentials.json from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# React UI API base URL (optional; defaults to http://localhost:8000)
VITE_API_URL=http://localhost:8000
