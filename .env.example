# Anthropic API key for Claude vision document extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection (use localhost for local dev, db service name in Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/freight_ap
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/freight_ap_test

# Redis connection (use localhost for local dev, redis service name in Docker)
REDIS_URL=redis://localhost:6379/0

# Gmail OAuth files (download credentials.json from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json

# React UI API base URL (optional; defaults to http://localhost:8000)
VITE_API_URL=http://localhost:8000
